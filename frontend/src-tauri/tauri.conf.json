{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Second Brain",
  "version": "0.1.0",
  "identifier": "com.secondbrain.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Second Brain",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* http://127.0.0.1:* tauri://localhost; img-src 'self' data: asset: https://*.ytimg.com; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "sidecar/sidecar-python"
    ]
  }
}
